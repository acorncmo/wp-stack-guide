{# 404.twig -- Page not found #}
{% extends 'base.twig' %}

{% block content %}
  <section class="py-24 px-6 text-center max-w-2xl mx-auto">
    <h1 class="font-display text-4xl mb-4">Page not found</h1>
    <p class="text-brand-muted mb-8">The page you are looking for does not exist or has been moved.</p>
    <a href="{{ site_url }}" class="inline-block bg-brand-dark text-white px-6 py-3 rounded-full font-sans text-sm font-semibold hover:bg-brand-accent transition-colors">
      Back to homepage
    </a>
  </section>
{% endblock %}
