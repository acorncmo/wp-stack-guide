{# single.twig -- Single blog post template #}
{% extends 'base.twig' %}

{% block content %}
  <article>
    <header class="bg-brand-dark text-white py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="font-display text-4xl mb-4">{{ post.title }}</h1>
        <p class="text-brand-light/70">{{ post.date }}</p>
      </div>
    </header>

    <div class="py-12 px-6 max-w-3xl mx-auto prose font-sans">
      {{ post.content }}
    </div>
  </article>
{% endblock %}
